{
  "expo": {
    "name": "Wunderlist",
    "slug": "wunderlist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wunderlist",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07070F",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ordman.wunderlist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Wunderlist reads shared images from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070F"
      },
      "package": "com.ordman.wunderlist"
    },
    "plugins": [
      "expo-router",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": ["text/*"],
          "androidMultiIntentFilters": ["image/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://wunderlist-app.vercel.app",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
